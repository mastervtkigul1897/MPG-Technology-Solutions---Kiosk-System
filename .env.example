APP_NAME=Kiosk System
# Browser tab suffix (after application name). Not shown in the sidebar.
APP_BRAND_SUFFIX=MPG Technology Solutions
APP_DEBUG=false
# Local (php -S ... 8080): use http://localhost:8080 — port must match the browser and php -S
# Production: https://your-domain.com (no trailing slash)
APP_URL=http://localhost:8080

# Shown on the subscription-ended screen (mailto link). Optional.
APP_OWNER_EMAIL=

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_CHARSET=utf8mb4

# Optional: Wi-Fi / Ethernet thermal printer (raw ESC/POS on TCP port 9100).
# The PHP server must be able to reach this IP (same LAN as the printer).
# Leave empty to hide the "Wi-Fi / LAN" receipt button.
THERMAL_PRINTER_HOST=
THERMAL_PRINTER_PORT=9100
THERMAL_PRINTER_TIMEOUT=3
