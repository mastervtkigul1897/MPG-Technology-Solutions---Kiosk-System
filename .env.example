APP_NAME=Laundry System
# Browser tab suffix (after application name). Not shown in the sidebar.
APP_BRAND_SUFFIX=MPG Technology Solutions
APP_DEBUG=false
# Local (php -S ... 8080): use http://localhost:8080 — port must match the browser and php -S
# Production: https://your-domain.com (no trailing slash)
APP_URL=http://localhost:8080

# Shown on the subscription-ended screen (mailto link). Optional.
APP_OWNER_EMAIL=

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=laundry_system
DB_USERNAME=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_CHARSET=utf8mb4

MAIL_MAILER=smtp
MAIL_HOST=mpgtechnologysolutions.com
MAIL_PORT=465
MAIL_USERNAME=notification@mpgtechnologysolutions.com
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=notification@mpgtechnologysolutions.com
MAIL_FROM_NAME="MPG Laundry Management System"
# Optional inbox-deliverability settings (recommended for production):
# - MAIL_EHLO_DOMAIN should be your sending domain (or mail subdomain), not localhost.
# - MAIL_MESSAGE_ID_DOMAIN should match the same domain used by MAIL_FROM_ADDRESS.
# - MAIL_RETURN_PATH should be an inbox on the same verified domain.
# - MAIL_REPLY_TO_* can be your support inbox.
MAIL_REPLY_TO_ADDRESS=support@mpgtechnologysolutions.com
MAIL_REPLY_TO_NAME="MPG Support"
MAIL_RETURN_PATH=bounces@mpgtechnologysolutions.com
MAIL_EHLO_DOMAIN=mpgtechnologysolutions.com
MAIL_MESSAGE_ID_DOMAIN=mpgtechnologysolutions.com

# Domain DNS requirements to avoid spam folders:
# 1) SPF TXT at root: "v=spf1 include:YOUR_MAIL_PROVIDER ~all"
# 2) DKIM TXT/CNAME records from your mail provider (must pass)
# 3) DMARC TXT at _dmarc:
#    "v=DMARC1; p=quarantine; rua=mailto:dmarc@mpgtechnologysolutions.com; adkim=s; aspf=s"
# 4) Use the same domain for MAIL_FROM_ADDRESS, MAIL_RETURN_PATH, SPF, and DKIM alignment.

# Optional: Wi-Fi / Ethernet thermal printer (raw ESC/POS on TCP port 9100).
# The PHP server must be able to reach this IP (same LAN as the printer).
# Leave empty to hide the "Wi-Fi / LAN" receipt button.
THERMAL_PRINTER_HOST=
THERMAL_PRINTER_PORT=9100
THERMAL_PRINTER_TIMEOUT=3

# Web Bluetooth "Bluetooth print" is toggled in config/app.php (thermal_receipt_show_bluetooth), not here.
