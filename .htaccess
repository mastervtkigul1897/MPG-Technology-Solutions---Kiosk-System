<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Never expose backup storage through web requests.
    RewriteRule ^storage/backups(?:/|$) - [F,L,NC]
    RewriteRule ^public/storage/backups(?:/|$) - [F,L,NC]

    # Kung may direktang /public/ sa address bar, i-301 papunta sa malinis na URL (walang /public)
    RewriteCond %{THE_REQUEST} \s/+public/ [NC]
    RewriteRule ^public/(.*)$ /$1 [R=301,L]

    # Ilipat ang lahat ng request sa public/ (internal rewrite — domain lang ang makikita)
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Huwag ipakita ang directory listing sa root
Options -Indexes
