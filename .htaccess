<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Never expose backup storage through web requests.
    RewriteRule ^storage/backups(?:/|$) - [F,L,NC]
    RewriteRule ^public/storage/backups(?:/|$) - [F,L,NC]

    # If /public/ appears in the address bar, 301 to a clean URL (no /public)
    RewriteCond %{THE_REQUEST} \s/+public/ [NC]
    RewriteRule ^public/(.*)$ /$1 [R=301,L]

    # Route all requests to public/ (internal rewrite — only the domain is visible)
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Do not show directory listing at the document root
Options -Indexes
